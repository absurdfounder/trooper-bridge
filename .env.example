# ===========================================
# OpenClaw Bridge — environment variables
# ===========================================

# Port the bridge listens on (default 3002)
# PORT=3002

# ===========================================
# Bridge auth (server-to-server)
# ===========================================

# Shared secret used by any caller (Trooper Render API, Cloudflare control
# Worker, etc.) to authenticate to the bridge via `Authorization: Bearer <token>`.
# Leave unset for local dev (bridge runs without auth).
# BRIDGE_AUTH_TOKEN=your_shared_secret_here

# Shared secret used by this bridge when calling Trooper runtime endpoints.
# When set with MISSION_CONTROL_URL and ORG_ID, the bridge checks quota before
# starting provider-backed OpenClaw work and reports usage after runs.
# RUNTIME_AUTH_SECRET=your_runtime_secret_here
# MISSION_CONTROL_URL=https://your-trooper-api.example.com
# ORG_ID=your_org_id
# OPENCLAW_QUOTA_ENFORCEMENT=1
# Default source for provider keys without per-provider metadata. Trooper-managed
# cloud hosts keep this at 1; manual/self-hosted installs set it to 0. Runtime
# settings can still mark individual active provider keys as "trooper" or "byo".
# OPENCLAW_COMPANY_PROVIDER_KEYS=1

# ===========================================
# OpenClaw gateway connection
# ===========================================

# URL of the OpenClaw gateway (native protocol WebSocket)
# OPENCLAW_URL=ws://openclaw-gateway:3000
# OPENCLAW_TOKEN=your_gateway_token_here

# ===========================================
# Firebase (optional, for frontend → bridge calls)
# ===========================================

# FIREBASE_PROJECT_ID=ai-copilot-104
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ai-copilot-104.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
